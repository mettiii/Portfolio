<odoo>
    <!-- Tree View for Exam Results -->
    <record id="view_exam_result_tree" model="ir.ui.view">
        <field name="name">exam.result.tree</field>
        <field name="model">exam.result</field>
        <field name="arch" type="xml">
            <tree string="Exam Results">
                <field name="employee_id"/>
                <field name="exam_id"/>
                <field name="score"/>
                <field name="passed"/>
                <field name="remarks"/>
            </tree>
        </field>
    </record>

    <!-- Form View for Exam Results -->
    <record id="view_exam_result_form" model="ir.ui.view">
        <field name="name">exam.result.form</field>
        <field name="model">exam.result</field>
        <field name="arch" type="xml">
            <form string="Exam Result">
                <sheet>
                    <group>
                        <field name="employee_id" required="1"/>
                        <field name="exam_id" required="1"/>
                        <field name="score"/>
                        <field name="passed" readonly="1"/>
                        <field name="remarks"/>
                    </group>
                    <footer>
                        <button string="Print Scorecard" type="object" name="action_print_scorecard" class="oe_highlight"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Exam Results -->
    <record id="action_exam_result" model="ir.actions.act_window">
        <field name="name">Exam Results</field>
        <field name="res_model">exam.result</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create the first exam result
            </p>
        </field>
    </record>

    <!-- Menu Item for Exam Results -->
    <record id="menu_exam_results" model="ir.ui.menu">
        <field name="name">Exam Results</field>
        <field name="parent_id" ref="exam_management.menu_exam_root"/> <!-- Adjust to your menu structure -->
        <field name="action" ref="action_exam_result"/>
        <field name="sequence" eval="10"/>
    </record>
</odoo>
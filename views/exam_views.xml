<odoo>
    <record id="view_exam_management_form" model="ir.ui.view">
        <field name="name">exam.management.form</field>
        <field name="model">exam.management</field>
        <field name="arch" type="xml">
            <form string="Exam Management">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>

                    <group string="Upload Questions">
                        <field name="question_file" filename="question_file_name"/>
                        <field name="question_file_name"/>
                        <button name="import_questions" type="object" string="Import Questions" class="btn-primary"/>
                    </group>

                    <notebook>
                        <page string="Imported Questions">
                            <field name="question_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="question_type"/>
                                    <field name="options"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_exam_management_tree" model="ir.ui.view">
        <field name="name">exam.management.tree</field>
        <field name="model">exam.management</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_exam_management" model="ir.actions.act_window">
        <field name="name">Exam Management</field>
        <field name="res_model">exam.management</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

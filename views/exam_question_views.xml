<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_exam_question_tree" model="ir.ui.view">
            <field name="name">exam.question.tree</field>
            <field name="model">exam.question</field>
            <field name="arch" type="xml">
                <tree string="Question Bank">
                    <field name="name" string="Question Text"/>
                    <field name="question_type" string="Question Type"/>
                    <field name="option_a" string="Option A" optional="hide"/>
                    <field name="option_b" string="Option B" optional="hide"/>
                    <field name="option_c" string="Option C" optional="hide"/>
                    <field name="option_d" string="Option D" optional="hide"/>
                    <field name="correct_answer" string="Correct Answer"/>
                    <field name="exam_type"/>
                    <field name="job_grade" optional="hide"/>
                    <field name="job_role" optional="hide"/>

                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_exam_question_form" model="ir.ui.view">
            <field name="name">exam.question.form</field>
            <field name="model">exam.question</field>
            <field name="arch" type="xml">
                <form string="Question">
                    <sheet>
                        <group>
                            <field name="exam_type" required="1"/>
                            <field name="job_grade"/>
                            <field name="job_role"/>
                            <field name="name" string="Question Text" required="1"/>
                            <field name="question_type" string="Question Type" required="1"/>
                            <field name="correct_answer" string="Correct Answer" invisible="question_type=='essay'"/>
                            <field name="exam_ids" widget="many2many_tags" options="{'no_create': True}"
                                   string="Used In Exams"/>
                        </group>

                        <group string="Multiple Choice Options" invisible="question_type!='multiple_choice'">
                            <field name="option_a" string="Option A" invisible="question_type!='multiple_choice'"/>
                            <field name="option_b" string="Option B" invisible="question_type!='multiple_choice'"/>
                            <field name="option_c" string="Option C" invisible="question_type!='multiple_choice'"/>
                            <field name="option_d" string="Option D" invisible="question_type!='multiple_choice'"/>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action for Question Bank -->
        <record id="action_exam_question_bank" model="ir.actions.act_window">
            <field name="name">Question Bank</field>
            <field name="res_model">exam.question</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage your exam questions here.</p>
            </field>
        </record>

    </data>
</odoo>
